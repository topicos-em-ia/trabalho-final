relatorio/*.aux
relatorio/*.bbl
relatorio/*.blg
relatorio/*.fdb_latexmk
relatorio/*.fls
relatorio/*.log
relatorio/*.out

# Artefatos de build do LaTeX (slides)
slides/*.aux
slides/*.log
