# Diretórios de trabalho locais
.plans/
.logs/
plans/
data/

# Arquivos legados e pesados (arquivados localmente, fora do git)
_legado/

# Datasets grandes (baixados do Hugging Face quando necessário)
questoes/q5-rag/dados/

# Artefatos pesados (modelos completos e zips não vão pro git)
*.zip
*.safetensors
# exceção: adaptadores LoRA leves são entregáveis e ficam versionados
!questoes/q3-lora-qlora/adaptadores/**/*.safetensors
!questoes/q4-destilacao/adaptador-lora/**/*.safetensors

# Ambientes e caches
.venv/
__pycache__/
*.pyc
questoes/q5-rag/chroma_db/

